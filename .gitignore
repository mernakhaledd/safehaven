# ── Secrets (NEVER commit) ───────────────────────────────────────────
.env
.env.*
**/supabase_service_key.txt
**/household_id.txt
supabase_setup_push.sql
**/google-services.json
**/*service-account*.json
**/*serviceaccount*.json

# ── Private / biometric data (do not publish faces) ──────────────────
**/dataset/known_faces/
**/embeddings/*.pkl
**/snapshots/

# ── Python ───────────────────────────────────────────────────────────
**/venv*/
**/.venv/
**/__pycache__/
*.pyc
*.pyo

# ── Node / Expo (mobile app) ─────────────────────────────────────────
**/node_modules/
**/.expo/
**/dist/
**/web-build/

# ── Backups / scratch ────────────────────────────────────────────────
*.bak
*.ORIGINAL
fall_deploy_for_review.py

# ── Nested git backups (the app keeps its own .git for EAS builds) ────
**/.git_old/
**/.git_off/

# ── Archives / OS junk ───────────────────────────────────────────────
*.zip
__MACOSX/
.DS_Store
Thumbs.db
